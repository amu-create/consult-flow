# Database
# Optional for local development. If omitted, the app falls back to file:./prisma/dev.db.
# Required for Turso/LibSQL deployments.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# AI analysis
# Required for Gemini-powered analysis endpoints.
GEMINI_API_KEY=

# Public app URL
# Required for production OAuth callbacks and notification links.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Kakao OAuth
# Required for Kakao login and Kakao "send to me" flows.
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

# SMS notifications
# Required for live Solapi SMS sends. Leave blank to use mock/fallback behavior where supported.
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_NUMBER=

# Vercel Blob
# Required by @vercel/blob upload/delete routes in deployed environments.
VERCEL_BLOB_READ_WRITE_TOKEN=
